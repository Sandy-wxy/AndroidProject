<?xml version="1.0" encoding="utf-8"?>
<com.example.focus_flow.core.ui.AuroraCoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment_content_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="66dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav_glass"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <LinearLayout
            android:id="@+id/nav_home"
            style="@style/WidgetFocusFlowNavContainer"
            android:contentDescription="@string/nav_home">

            <ImageView
                style="@style/WidgetFocusFlowNavIcon"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_home" />

            <com.google.android.material.textview.MaterialTextView
                style="@style/WidgetFocusFlowNavLabel"
                android:text="@string/nav_home" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_tasks"
            style="@style/WidgetFocusFlowNavContainer"
            android:contentDescription="@string/nav_tasks">

            <ImageView
                style="@style/WidgetFocusFlowNavIcon"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_tasks" />

            <com.google.android.material.textview.MaterialTextView
                style="@style/WidgetFocusFlowNavLabel"
                android:text="@string/nav_tasks" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_focus"
            style="@style/WidgetFocusFlowNavContainer"
            android:contentDescription="@string/nav_focus">

            <ImageView
                style="@style/WidgetFocusFlowNavIcon"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_focus" />

            <com.google.android.material.textview.MaterialTextView
                style="@style/WidgetFocusFlowNavLabel"
                android:text="@string/nav_focus" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_forest"
            style="@style/WidgetFocusFlowNavContainer"
            android:contentDescription="@string/nav_forest">

            <ImageView
                style="@style/WidgetFocusFlowNavIcon"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_forest" />

            <com.google.android.material.textview.MaterialTextView
                style="@style/WidgetFocusFlowNavLabel"
                android:text="@string/nav_forest" />
        </LinearLayout>
    </LinearLayout>

</com.example.focus_flow.core.ui.AuroraCoordinatorLayout>
