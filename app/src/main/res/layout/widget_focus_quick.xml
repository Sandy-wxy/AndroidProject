<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_focus"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@drawable/bg_widget_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="今日任务"
            android:textColor="#201B12"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_add"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_widget_add"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFFFF"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_running"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_running_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在专注"
            android:textColor="#F2C94C"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_running_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingTop="4dp"
            android:text="任务名称"
            android:textColor="#FFFFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Chronometer
            android:id="@+id/widget_countdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="5dp"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_running_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击进入专注舱"
            android:textColor="#AEB3BC"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/widget_task_row_1"
            style="@style/WidgetFocusTaskRow">

            <TextView
                android:id="@+id/widget_task_title_1"
                style="@style/WidgetFocusTaskTitle" />

            <TextView
                android:id="@+id/widget_task_detail_1"
                style="@style/WidgetFocusTaskDetail" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_task_row_2"
            style="@style/WidgetFocusTaskRow">

            <TextView
                android:id="@+id/widget_task_title_2"
                style="@style/WidgetFocusTaskTitle" />

            <TextView
                android:id="@+id/widget_task_detail_2"
                style="@style/WidgetFocusTaskDetail" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_task_row_3"
            style="@style/WidgetFocusTaskRow">

            <TextView
                android:id="@+id/widget_task_title_3"
                style="@style/WidgetFocusTaskTitle" />

            <TextView
                android:id="@+id/widget_task_detail_3"
                style="@style/WidgetFocusTaskDetail" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="今日暂无任务\n点击右上角 ＋ 添加任务"
            android:textColor="#B8BBC1"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
